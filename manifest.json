{
    "manifest_version": 3,
    "name": "JSON Formatter & Viewer",
    "description": "Advanced tool for formatting and viewing JSON data in the browser.",
    "version": "1.0",
    "permissions": ["scripting", "storage"],
    "icons": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    },
    "content_scripts": [
      {
        "matches": ["https://learn.ucu.edu.ua/mod/quiz/*"],
        "js": ["autoAnswer.js"],
        "run_at": "document_idle"
      }
    ],
    "web_accessible_resources": [
      {
        "resources": ["answers.json"],
        "matches": ["<all_urls>"]
      }
    ],
    "action": {
      "default_title": "JSON Formatter",
      "default_icon": "icon.png",
      "default_popup": "popup.html"
    }
  }
